"help.launch_at_login" = "Starts the app after login. Only rules with auto-connect enabled will connect automatically.";
"help.rule_state.title" = "Availability and connection state";
"help.rule_state.body" = "Enabled means the rule is available to run; it does not mean the rule is connected. Use Connect and Disconnect to control the current SSH session. Disabling a running rule disconnects it.";
"help.rule_type.title" = "Choose the direction that matches your task";
"help.rule_type.body" = "Proxy provides a SOCKS5 endpoint and can also provide an HTTP/HTTPS endpoint through the same SSH tunnel. Local Forward opens a port on this Mac for a service reachable from the SSH server. Remote Forward opens a port on the SSH server for a service running on this Mac.";
"help.auto_connect" = "Connects this rule when SSH Proxy Tray starts. Launch at login is a separate app-wide setting.";
"help.authentication.title" = "Choose how OpenSSH authenticates";
"help.authentication.body" = "SSH Config is best when the host, user, key, jump host, or port already exists in ~/.ssh/config. Key / Certificate uses explicit connection fields. Password prompts at connection time and is saved only when Keychain storage is enabled.";
"help.advanced.title" = "Optional OpenSSH connection controls";
"help.advanced.body" = "ProxyJump routes through a bastion host. Compression trades CPU for less network traffic. Timeout and keepalive settings control how quickly failed or stalled connections are detected. Leave the defaults unless your SSH environment requires different values.";
"help.proxy_jump" = "Connect through an intermediate SSH host, equivalent to ssh -J.";
"help.compression" = "Enables SSH compression. It can help on slow links but may add CPU overhead.";
"help.connect_timeout" = "Maximum time to wait while establishing the SSH connection.";
"help.server_alive_interval" = "How often SSH sends an encrypted keepalive message. Use 0 to disable.";
"help.server_alive_count" = "Disconnect after this many unanswered keepalive messages.";
"help.local_bind_address" = "The local interface that accepts connections. Loopback keeps the listener available only on this Mac.";
"help.local_proxy_port" = "Configure your browser or application to use this local SOCKS5 port.";
"help.provide_http_proxy" = "Adds a local HTTP proxy endpoint that uses the same SSH tunnel. HTTPS is supported through the HTTP CONNECT method.";
"help.http_proxy_port" = "Use this port in applications that accept an HTTP proxy. Both HTTP requests and HTTPS CONNECT use the same SSH tunnel as SOCKS.";
"help.local_listen_port" = "Connect to this port on your Mac to reach the remote destination through SSH.";
"help.remote_destination_host" = "A host that the SSH server can reach. 127.0.0.1 means the SSH server itself.";
"help.remote_destination_port" = "The service port reached from the SSH server side.";
"help.remote_bind_address" = "127.0.0.1 allows access only from the SSH server. 0.0.0.0 may expose the port to other machines and requires GatewayPorts.";
"help.remote_listen_port" = "Connect to this port on the SSH server to reach the local target.";
"help.local_target_host" = "The service host as seen from this Mac. Usually 127.0.0.1.";
"help.local_target_port" = "The port where the target service is already running on this Mac.";
"help.mode.proxy" = "Local app -> SOCKS or HTTP proxy port -> one SSH tunnel -> network. Use either endpoint without opening a second SSH connection.";
"help.mode.local_forward" = "This Mac local port -> SSH tunnel -> service reachable from the SSH server.";
"help.mode.remote_forward" = "SSH server remote port -> SSH tunnel -> service running on this Mac.";
"help.forwarding.proxy.title" = "Proxy: SOCKS and HTTP endpoints share one SSH tunnel";
"help.forwarding.proxy.body" = "SOCKS flow: app -> local SOCKS5 port -> encrypted SSH tunnel -> destination. HTTP flow: app -> local HTTP proxy port -> local protocol adapter -> the same SOCKS5 tunnel. HTTPS uses HTTP CONNECT. Two local ports are required because SOCKS and HTTP are different protocols, but only one SSH connection is opened.";
"help.forwarding.local.title" = "Local Forward: access a remote-side service from this Mac";
"help.forwarding.local.body" = "Flow: this Mac's local listen port -> encrypted SSH connection -> destination host and port reachable from the SSH server. Example: local 8080 can reach a proxy or database on the remote side.";
"help.forwarding.remote.title" = "Remote Forward: access a service on this Mac from the SSH server";
"help.forwarding.remote.body" = "Flow: remote listen port on the SSH server -> encrypted SSH connection -> target service on this Mac. Example: remote 23000 can reach a local development server on port 3000. Keep the remote bind address at 127.0.0.1 unless broader exposure is intentional and secured.";
